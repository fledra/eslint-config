{
  "name": "@fledra/eslint-config",
  "description": "One opinionated config for ESLint",
  "version": "3.0.2",
  "license": "MIT",
  "type": "module",
  "author": "Baran D. <baran@fledra.dev> (https://fledra.dev)",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fledra/eslint-config.git"
  },
  "bugs": {
    "url": "https://github.com/fledra/eslint-config/issues"
  },
  "packageManager": "pnpm@10.30.0",
  "scripts": {
    "prepare": "husky",
    "build": "pnpm typegen && tsup --clean --dts",
    "dev": "pnpx @eslint/config-inspector --config eslint.config.ts",
    "test": "vitest --run",
    "test:dev": "vitest",
    "prepack": "pnpm build",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "typegen": "tsx scripts/typegen.ts",
    "typecheck": "tsc --noEmit",
    "bump": "pnpx changelogen@latest --release"
  },
  "dependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@eslint/markdown": "^7.5.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint-flat-config-utils": "^3.0.1",
    "eslint-merge-processors": "^2.0.0",
    "eslint-plugin-antfu": "^3.2.2",
    "eslint-plugin-import-lite": "^0.5.2",
    "eslint-plugin-jsdoc": "^62.7.1",
    "eslint-plugin-jsonc": "^3.1.1",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-toml": "^1.3.1",
    "eslint-plugin-unicorn": "^63.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-vue": "^10.8.0",
    "eslint-plugin-yml": "^3.3.1",
    "eslint-processor-vue-blocks": "^2.0.0",
    "find-up-simple": "^1.0.1",
    "globals": "^17.4.0",
    "local-pkg": "^1.1.2",
    "toml-eslint-parser": "^1.0.3",
    "vue-eslint-parser": "^10.4.0",
    "yaml-eslint-parser": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "@typescript-eslint/typescript-estree": "^8.56.1",
    "@typescript-eslint/utils": "^8.56.1",
    "eslint": "^10.0.3",
    "eslint-typegen": "^2.3.1",
    "eslint-vitest-rule-tester": "^3.1.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.3.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "eslint": "^10.0.0"
  },
  "changelog": {
    "output": false,
    "noAuthors": true
  }
}
